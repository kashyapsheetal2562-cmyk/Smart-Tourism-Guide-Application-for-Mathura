# Environment Configuration for Mathura Tourism Project
# Copy this file to .env and fill in your actual API keys

# ============================================================================
# DJANGO CORE SETTINGS
# ============================================================================

# Django Settings (IMPORTANT: Change in production!)
DEBUG=False
SECRET_KEY=generate-a-new-secret-key-for-production

# For PythonAnywhere, use:
ALLOWED_HOSTS=smarttourism.pythonanywhere.com,localhost,127.0.0.1

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Database (using SQLite by default)
# For PythonAnywhere, keep SQLite for shared hosting
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3

# ============================================================================
# API KEYS - Get these for free from:
# ============================================================================

# OpenRouter API Key (for AI Chatbot - FREE)
# Get free tier at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemma-3n-e4b-it:free
OPENROUTER_FALLBACK_MODELS=google/gemma-3n-e2b-it:free,google/gemma-3-4b-it:free
OPENROUTER_MAX_TOKENS=900

# Google Maps API Key
# Get free tier at: https://cloud.google.com/maps-platform
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenWeatherMap API Key (Optional, for weather features)
# Get free tier at: https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here

# ============================================================================
# EMAIL SETTINGS (Optional)
# ============================================================================

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password

# ============================================================================
# CORS SETTINGS
# ============================================================================

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# ============================================================================
# SECURITY (Change in Production)
# ============================================================================

CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# For PythonAnywhere production:
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

